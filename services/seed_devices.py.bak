import os
import sqlite3

BASE_DIR = os.path.dirname(os.path.abspath(__file__))

DB_PATH = os.path.abspath(
    os.path.join(
        BASE_DIR,
        "..",
        "database",
        "inventory.db"
    )
)

print(DB_PATH)
conn = sqlite3.connect(DB_PATH)
cursor = conn.cursor()

tables = cursor.execute("""
SELECT name
FROM sqlite_master
WHERE type='table'
""").fetchall()

print(tables)



departments = [
    {
        "department": "Accounting",
        "prefix": "LAXACTPC",
        "subnet": "192.168.100.0/27",
        "gateway": "192.168.100.1",
        "ip_start": 7,
        "cost_center": "FIN-1001"
    },
    {
        "department": "IT",
        "prefix": "LAXITSPC",
        "subnet": "192.168.100.32/27",
        "gateway": "192.168.100.33",
        "ip_start": 39,
        "cost_center": "IT-2000"
    },
    {
        "department": "HR",
        "prefix": "LAXHRPC",
        "subnet": "192.168.100.64/27",
        "gateway": "192.168.100.65",
        "ip_start": 71,
        "cost_center": "HR-4001"
    },
    {
        "department": "Marketing",
        "prefix": "LAXMKTPC",
        "subnet": "192.168.100.96/27",
        "gateway": "192.168.100.97",
        "ip_start": 103,
        "cost_center": "MKT-5001"
    },
    {
        "department": "Operations",
        "prefix": "LAXOPSPC",
        "subnet": "192.168.100.128/27",
        "gateway": "192.168.100.129",
        "ip_start": 135,
        "cost_center": "OPS-3002"
    }
]

owners = [
    "James Smith","Michael Johnson","Robert Williams","David Brown","William Jones",
    "Richard Garcia","Joseph Miller","Thomas Davis","Charles Rodriguez","Daniel Martinez",
    "Matthew Hernandez","Anthony Lopez","Mark Gonzalez","Donald Wilson","Steven Anderson",
    "Paul Thomas","Andrew Taylor","Joshua Moore","Kenneth Jackson","Kevin Martin",
    "Brian Lee","George Perez","Edward Thompson","Ronald White","Timothy Harris",
    "Jason Sanchez","Jeffrey Clark","Ryan Ramirez","Jacob Lewis","Gary Robinson",
    "Nicholas Walker","Eric Young","Jonathan Allen","Stephen King","Larry Wright",
    "Justin Scott","Scott Torres","Brandon Nguyen","Benjamin Hill","Samuel Flores",
    "Gregory Green","Alexander Adams","Patrick Nelson","Jack Baker","Dennis Hall",
    "Jerry Rivera","Tyler Campbell","Aaron Mitchell","Jose Carter","Adam Roberts"
]

idx = 0

for dept in departments:

    for n in range(1,11):

        hostname = f"{dept['prefix']}{n:03d}"

        ip = f"192.168.100.{dept['ip_start'] + n - 1}"

        owner = owners[idx]
        idx += 1

        status = "Online"

        if hostname in [
            "LAXACTPC009",
            "LAXHRPC007",
            "LAXOPSPC010"
        ]:
            status = "Offline"

        cursor.execute("""
            INSERT INTO devices(
            hostname,
            owner,
            department,
            ip_address,
            subnet,
            gateway,
            status,
            last_seen,
            location,
            cost_center,
            asset_tag,
            serial_number,
            purchase_date,
            warranty_expiration,
            retirement_date
        )
        VALUES(
            ?, ?, ?, ?, ?, ?,
            ?, ?, ?, ?, ?, ?,
            ?, ?, ?
        )
        """, (
            hostname,
            owner,
            dept["department"],
            ip,
            dept["subnet"],
            dept["gateway"],
            status,
            "2026-06-20",
            "Los Angeles",
            dept["cost_center"],
            f"AT-{idx:05d}",
            f"SN-{100000+idx}",
            "2024-01-15",
            "2027-01-15",
            "2029-01-15"
        ))



device_table = cursor.execute("""
SELECT COUNT(*)
FROM devices
""").fetchall()

print(device_table)

conn.commit()
conn.close()

print("50 devices inserted")